<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:views="clr-namespace:LocalWallet.Views"
       x:Class="LocalWallet.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Title="LocalWallet">

    <TabBar>
        <ShellContent Title="Главная"
                      ContentTemplate="{DataTemplate views:DashboardPage}"
                      Route="dashboard">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MatIcon" Glyph="&#xe88a;" />
            </ShellContent.Icon>
        </ShellContent>
        <ShellContent Title="Операции"
                      ContentTemplate="{DataTemplate views:TransactionsPage}"
                      Route="transactions">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MatIcon" Glyph="&#xe8b0;" />
            </ShellContent.Icon>
        </ShellContent>
        <ShellContent Title="Валюты"
                      ContentTemplate="{DataTemplate views:MultiCurrencyPage}"
                      Route="multicurrency">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MatIcon" Glyph="&#xe8d4;" />
            </ShellContent.Icon>
        </ShellContent>
        <ShellContent Title="Статистика"
                      ContentTemplate="{DataTemplate views:StatisticsPage}"
                      Route="statistics">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MatIcon" Glyph="&#xe6c4;" />
            </ShellContent.Icon>
        </ShellContent>
        <ShellContent Title="Настройки"
                      ContentTemplate="{DataTemplate views:SettingsPage}"
                      Route="settings">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MatIcon" Glyph="&#xe8b8;" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
