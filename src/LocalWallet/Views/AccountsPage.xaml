<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.AccountsPage"
             x:DataType="vm:AccountsViewModel"
             Title="Счета">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="Новый счёт" FontAttributes="Bold" />
            <Entry Placeholder="Название" Text="{Binding NewAccountName, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Entry Grid.Column="0"
                       Placeholder="Валюта (напр. PLN)"
                       Text="{Binding NewAccountCurrency, Mode=TwoWay}"
                       MaxLength="3" />
                <Entry Grid.Column="1"
                       Placeholder="Начальный баланс"
                       Text="{Binding NewAccountInitialBalance, Mode=TwoWay}"
                       Keyboard="Numeric" />
            </Grid>
            <Button Text="Добавить"
                    Command="{Binding AddCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:Account">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Удалить"
                                           BackgroundColor="#D32F2F"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AccountsViewModel}}, Path=DeleteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Grid Padding="12" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" />
                            <Label Grid.Column="1">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0:0.00} {1}">
                                        <Binding Path="InitialBalance" />
                                        <Binding Path="Currency" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
