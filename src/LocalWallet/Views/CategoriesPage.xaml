<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.CategoriesPage"
             x:DataType="vm:CategoriesViewModel"
             BackgroundColor="Transparent"
             Title="Категории">

    <Grid Background="{StaticResource AmbientBg}">
        <Grid RowDefinitions="Auto,*" Padding="16,12,16,0" RowSpacing="14">

            <Border Grid.Row="0" Style="{StaticResource GlassCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Новая категория" Style="{StaticResource H2}" />

                    <Border Style="{StaticResource GlassInput}" Padding="6">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="6" HeightRequest="44">
                            <Border Grid.Column="0" Stroke="Transparent" BackgroundColor="{Binding ExpenseBg}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetExpenseCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="− Расход" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="{Binding ExpenseText}" />
                            </Border>
                            <Border Grid.Column="1" Stroke="Transparent" BackgroundColor="{Binding IncomeBg}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetIncomeCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="+ Доход" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="{Binding IncomeText}" />
                            </Border>
                        </Grid>
                    </Border>

                    <Label Text="Название" Style="{StaticResource Caption}" />
                    <Border Style="{StaticResource GlassInput}">
                        <Entry Placeholder="Например: Еда, Транспорт, Зарплата"
                               BackgroundColor="Transparent"
                               Text="{Binding NewCategoryName, Mode=TwoWay}" />
                    </Border>

                    <Label Text="Область" Style="{StaticResource Caption}" />
                    <Border Style="{StaticResource GlassInput}">
                        <Picker ItemsSource="{Binding AvailableScopes}"
                                BackgroundColor="Transparent"
                                SelectedItem="{Binding SelectedScope, Mode=TwoWay}"
                                ItemDisplayBinding="{Binding Label}"
                                Title="Личный или семейный" />
                    </Border>

                    <Button Text="Добавить категорию" Style="{StaticResource GlassPrimary}" Command="{Binding AddCommand}" Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None" VerticalScrollBarVisibility="Never">
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource GlassCard}" Margin="0,20">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="🏷" FontSize="36" HorizontalOptions="Center" />
                            <Label Text="Пока нет категорий" Style="{StaticResource H2}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:Category">
                        <SwipeView Margin="0,5">
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Удалить"
                                               BackgroundColor="{StaticResource DangerRed}"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=DeleteCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Style="{StaticResource GlassRow}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Type}" Style="{StaticResource Caption}" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>
