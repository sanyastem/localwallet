<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.CategoriesPage"
             x:DataType="vm:CategoriesViewModel"
             Title="Категории">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="14">

        <Border Grid.Row="0" Style="{StaticResource Card}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Новая категория" Style="{StaticResource SectionHeader}" />

                <Border StrokeShape="RoundRectangle 26"
                        Stroke="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceAlt}, Dark={StaticResource SurfaceAltDark}}"
                        Padding="4">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="4" HeightRequest="44">
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 22"
                                Stroke="Transparent"
                                BackgroundColor="{Binding ExpenseBg}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetExpenseCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="− Расход"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"
                                   TextColor="{Binding ExpenseText}" />
                        </Border>
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 22"
                                Stroke="Transparent"
                                BackgroundColor="{Binding IncomeBg}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetIncomeCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="+ Доход"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"
                                   TextColor="{Binding IncomeText}" />
                        </Border>
                    </Grid>
                </Border>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Название" Style="{StaticResource FieldLabel}" />
                    <Border Style="{StaticResource InputWrap}">
                        <Entry Placeholder="Например: Еда, Транспорт, Зарплата"
                               Text="{Binding NewCategoryName, Mode=TwoWay}" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Область" Style="{StaticResource FieldLabel}" />
                    <Border Style="{StaticResource InputWrap}">
                        <Picker ItemsSource="{Binding AvailableScopes}"
                                SelectedItem="{Binding SelectedScope, Mode=TwoWay}"
                                ItemDisplayBinding="{Binding Label}"
                                Title="Личный или семейный" />
                    </Border>
                </VerticalStackLayout>

                <Button Text="Добавить категорию" Command="{Binding AddCommand}" Margin="0,4,0,0" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20" Spacing="6">
                    <Label Text="Пока нет категорий" FontSize="14" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:Category">
                    <SwipeView Margin="0,4">
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Удалить"
                                           BackgroundColor="#D32F2F"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=DeleteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border Style="{StaticResource Card}" Padding="14">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Type}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
