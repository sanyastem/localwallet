<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.CategoriesPage"
             x:DataType="vm:CategoriesViewModel"
             Title="Категории">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="Новая категория" FontAttributes="Bold" />
            <Entry Placeholder="Название" Text="{Binding NewCategoryName, Mode=TwoWay}" />
            <HorizontalStackLayout Spacing="10">
                <RadioButton Content="Расход"
                             IsChecked="{Binding NewIsExpense, Mode=TwoWay}"
                             GroupName="catType" />
                <RadioButton Content="Доход" GroupName="catType">
                    <RadioButton.IsChecked>
                        <Binding Path="NewIsExpense" Mode="TwoWay">
                            <Binding.Converter>
                                <x:StaticResource Key="InverseBool" />
                            </Binding.Converter>
                        </Binding>
                    </RadioButton.IsChecked>
                </RadioButton>
            </HorizontalStackLayout>
            <Button Text="Добавить"
                    Command="{Binding AddCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:Category">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Удалить"
                                           BackgroundColor="#D32F2F"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=DeleteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Grid Padding="12" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding Type}" TextColor="{StaticResource Gray500}" />
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
