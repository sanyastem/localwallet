<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.ChatPage"
             x:DataType="vm:ChatViewModel"
             Title="{Binding FamilyName}">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceAlt}, Dark={StaticResource SurfaceAltDark}}"
                Stroke="Transparent"
                Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" VerticalOptions="Center" FontSize="13"
                       TextColor="{StaticResource Gray500}">
                    <Label.Text>
                        <MultiBinding StringFormat="В сети: {0}">
                            <Binding Path="OnlinePeersCount" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="#2E7D32"
                        Padding="8,3"
                        IsVisible="{Binding OnlinePeersCount, Converter={StaticResource CountToVisible}}">
                    <Label Text="LAN" TextColor="White" FontSize="11" FontAttributes="Bold" />
                </Border>
            </Grid>
        </Border>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy, Mode=TwoWay}"
                     Command="{Binding LoadCommand}">
            <CollectionView ItemsSource="{Binding Messages}"
                            SelectionMode="None"
                            x:Name="MessageList"
                            ItemsUpdatingScrollMode="KeepLastItemInView"
                            VerticalScrollBarVisibility="Never">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="24" Spacing="6">
                        <Label Text="Здесь пока пусто"
                               FontSize="16" FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Напишите первое сообщение — оно дойдёт до устройств семьи в этой Wi-Fi сети."
                               FontSize="13" TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChatBubble">
                        <Grid Padding="12,4" ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0"
                                    IsVisible="{Binding ShowAvatar}"
                                    WidthRequest="36" HeightRequest="36"
                                    StrokeShape="RoundRectangle 18"
                                    Stroke="Transparent"
                                    BackgroundColor="{Binding AvatarBg}"
                                    VerticalOptions="End"
                                    Margin="0,0,8,0">
                                <Label Text="{Binding Initials}"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Border Grid.Column="1"
                                    HorizontalOptions="{Binding BubbleAlignment}"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="Transparent"
                                    BackgroundColor="{Binding BubbleBg}"
                                    Padding="12,8"
                                    MaximumWidthRequest="320">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding AuthorName}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{Binding MetaFg}"
                                           IsVisible="{Binding ShowAvatar}" />
                                    <Label Text="{Binding Text}"
                                           TextColor="{Binding BubbleFg}"
                                           FontSize="15"
                                           LineBreakMode="WordWrap" />
                                    <Label Text="{Binding TimeFormatted}"
                                           FontSize="10"
                                           TextColor="{Binding MetaFg}"
                                           HorizontalOptions="End" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                Stroke="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}"
                StrokeThickness="1"
                Padding="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Border Grid.Column="0" Style="{StaticResource InputWrap}">
                    <Editor Placeholder="Сообщение"
                            Text="{Binding Draft, Mode=TwoWay}"
                            AutoSize="TextChanges"
                            MaximumHeightRequest="120"
                            FontSize="15" />
                </Border>
                <Button Grid.Column="1"
                        Text="▶"
                        FontSize="18"
                        WidthRequest="50" HeightRequest="50"
                        MinimumHeightRequest="50" MinimumWidthRequest="50"
                        CornerRadius="25"
                        Padding="0"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Command="{Binding SendCommand}" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
