<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             BackgroundColor="Transparent"
             Title="Главная">

    <Grid Background="{StaticResource AmbientBg}">
        <Grid RowDefinitions="Auto,*" Padding="16,12,16,0" RowSpacing="14">

            <!-- Hero: balance card. Accent gradient + specular edge. -->
            <Border Grid.Row="0"
                    Background="{StaticResource AccentBg}"
                    Stroke="{StaticResource GlassStroke}"
                    StrokeThickness="1"
                    Padding="22,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.18" Radius="18" Offset="0,8" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Общий баланс" TextColor="#CCFFFFFF" FontSize="13" />
                    <Label FontSize="40" TextColor="White" FontAttributes="Bold" LineHeight="1">
                        <Label.Text>
                            <MultiBinding StringFormat="{}{0:N2} {1}">
                                <Binding Path="TotalBalance" />
                                <Binding Path="BaseCurrency" />
                            </MultiBinding>
                        </Label.Text>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- Feed -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="10">
                <Label Grid.Row="0"
                       Text="Последние операции"
                       Style="{StaticResource H2}"
                       IsVisible="{Binding HasAccounts}"
                       Margin="4,4,0,0" />

                <RefreshView Grid.Row="1"
                             IsRefreshing="{Binding IsBusy, Mode=TwoWay}"
                             Command="{Binding LoadCommand}">
                    <CollectionView ItemsSource="{Binding RecentTransactions}"
                                    SelectionMode="None"
                                    VerticalScrollBarVisibility="Never">
                        <CollectionView.EmptyView>
                            <Border Style="{StaticResource GlassCard}"
                                    Padding="22"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Fill"
                                    Margin="0,24,0,0">
                                <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                                    <Label Text="💸"
                                           FontSize="42"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}" />
                                    <Label Text="Добро пожаловать"
                                           Style="{StaticResource H1}"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}" />
                                    <Label Text="Создайте первый счёт, чтобы начать вести учёт"
                                           Style="{StaticResource Caption}"
                                           HorizontalTextAlignment="Center"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}" />
                                    <Button Text="Создать счёт"
                                            Command="{Binding CreateAccountCommand}"
                                            Style="{StaticResource GlassPrimary}"
                                            HorizontalOptions="Center"
                                            MinimumWidthRequest="200"
                                            IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}" />

                                    <Label Text="Пока нет операций"
                                           Style="{StaticResource H2}"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding HasAccounts}" />
                                    <Label Text="Нажмите +, чтобы добавить первую"
                                           Style="{StaticResource Caption}"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding HasAccounts}" />
                                </VerticalStackLayout>
                            </Border>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TransactionDisplay">
                                <Border Style="{StaticResource GlassRow}" Margin="0,5">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding CategoryName}"
                                               FontSize="15"
                                               FontAttributes="Bold" />
                                        <Label Grid.Row="1" Grid.Column="0"
                                               Style="{StaticResource Caption}">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0:dd.MM HH:mm} · {1}">
                                                    <Binding Path="Date" />
                                                    <Binding Path="AccountName" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                               Text="{Binding AmountFormatted}"
                                               TextColor="{Binding AmountColor}"
                                               VerticalOptions="Center"
                                               FontSize="15"
                                               FontAttributes="Bold" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>

        </Grid>

        <!-- FAB: glass pill, no runtime blur, just tinted surface + ring + shadow -->
        <Button Text="+"
                FontSize="28"
                FontAttributes="Bold"
                WidthRequest="60" HeightRequest="60"
                MinimumHeightRequest="60" MinimumWidthRequest="60"
                CornerRadius="30"
                Padding="0"
                BackgroundColor="{StaticResource AccentGreen}"
                TextColor="White"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,24"
                IsVisible="{Binding HasAccounts}"
                Command="{Binding AddTransactionCommand}">
            <Button.Shadow>
                <Shadow Brush="Black" Opacity="0.25" Radius="14" Offset="0,6" />
            </Button.Shadow>
        </Button>

    </Grid>
</ContentPage>
