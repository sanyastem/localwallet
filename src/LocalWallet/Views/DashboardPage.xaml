<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Главная">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Primary}"
                StrokeShape="RoundRectangle 12"
                Stroke="Transparent"
                Padding="20">
            <VerticalStackLayout Spacing="6">
                <Label Text="Общий баланс" TextColor="White" FontSize="14" />
                <Label FontSize="34" TextColor="White" FontAttributes="Bold">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0:0.00} {1}">
                            <Binding Path="TotalBalance" />
                            <Binding Path="BaseCurrency" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="8">
            <Label Grid.Row="0"
                   Text="Последние операции"
                   FontSize="18" FontAttributes="Bold"
                   IsVisible="{Binding HasAccounts}" />

            <RefreshView Grid.Row="1"
                         IsRefreshing="{Binding IsBusy}"
                         Command="{Binding LoadCommand}">
                <CollectionView ItemsSource="{Binding RecentTransactions}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="24">
                            <Label Text="Добро пожаловать"
                                   FontSize="22" FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}" />
                            <Label Text="Создайте первый счёт, чтобы начать вести учёт"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}" />
                            <Button Text="Создать счёт"
                                    Command="{Binding CreateAccountCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}" />

                            <Label Text="Пока нет операций"
                                   FontSize="16" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding HasAccounts}" />
                            <Label Text="Нажмите +, чтобы добавить первую"
                                   FontSize="13" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding HasAccounts}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TransactionDisplay">
                            <Grid Padding="12,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding CategoryName}" FontAttributes="Bold" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       FontSize="12" TextColor="{StaticResource Gray500}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0:dd.MM HH:mm} · {1}">
                                            <Binding Path="Date" />
                                            <Binding Path="AccountName" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                       Text="{Binding AmountFormatted}"
                                       TextColor="{Binding AmountColor}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

        <Button Grid.Row="1"
                Text="+"
                FontSize="28"
                WidthRequest="60" HeightRequest="60"
                CornerRadius="30"
                Padding="0"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,8,16"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                IsVisible="{Binding HasAccounts}"
                Command="{Binding AddTransactionCommand}" />

    </Grid>
</ContentPage>
