<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.FamilyDetailsPage"
             x:DataType="vm:FamilyDetailsViewModel"
             BackgroundColor="Transparent"
             Title="Семья">

    <Grid Background="{StaticResource AmbientBg}">
        <ScrollView>
            <VerticalStackLayout Padding="16,12,16,24" Spacing="14">

                <!-- Hero summary -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Family.Name, FallbackValue=Семья}" Style="{StaticResource H1}" />
                        <Label Style="{StaticResource Caption}">
                            <Label.Text>
                                <MultiBinding StringFormat="Ваша роль: {0}">
                                    <Binding Path="Family.Role" FallbackValue="—" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label Style="{StaticResource Caption}">
                            <Label.Text>
                                <MultiBinding StringFormat="Последняя синхронизация: {0}">
                                    <Binding Path="LastSyncedText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <!-- Actions -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="Пригласить" Style="{StaticResource GlassSecondary}" Command="{Binding InviteCommand}" />
                    <Button Grid.Column="1" Text="Чат семьи" Style="{StaticResource GlassPrimary}" Command="{Binding OpenChatCommand}" />
                </Grid>

                <!-- Online peers -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Устройства в сети" Style="{StaticResource H2}" />
                    <Border Grid.Column="1" Style="{StaticResource GlassChip}" VerticalOptions="Center">
                        <Label Style="{StaticResource CaptionBold}">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}">
                                    <Binding Path="OnlinePeers.Count" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Border>
                </Grid>
                <Label Text="Найдены по Wi-Fi автоматически. Тап по устройству — синхронизация."
                       Style="{StaticResource Caption}" />

                <Border Style="{StaticResource GlassCard}" Padding="8">
                    <CollectionView ItemsSource="{Binding OnlinePeers}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Padding="14" Spacing="4" HorizontalOptions="Center">
                                <Label Text="Пока никого не видно"
                                       Style="{StaticResource Caption}"
                                       HorizontalOptions="Center" />
                                <Label Text="Откройте приложение на другом устройстве в той же Wi-Fi сети."
                                       Style="{StaticResource Caption}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:OnlinePeer">
                                <Grid Padding="10,8" ColumnDefinitions="12,*,Auto" ColumnSpacing="10">
                                    <Ellipse Grid.Column="0" WidthRequest="10" HeightRequest="10" Fill="#2E7D32" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1">
                                        <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                                        <Label Text="{Binding Endpoint}" Style="{StaticResource Caption}" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2"
                                            Text="Синхр."
                                            Style="{StaticResource GlassSecondary}"
                                            FontSize="12"
                                            Padding="10,4"
                                            HeightRequest="34"
                                            MinimumHeightRequest="34"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyDetailsViewModel}}, Path=SyncPeerCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <!-- Members -->
                <Label Text="Участники" Style="{StaticResource H2}" />
                <Border Style="{StaticResource GlassCard}" Padding="4">
                    <CollectionView ItemsSource="{Binding Members}" SelectionMode="None" HeightRequest="220">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:FamilyMember">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Отозвать"
                                                       BackgroundColor="{StaticResource DangerRed}"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyDetailsViewModel}}, Path=RevokeMemberCommand}"
                                                       CommandParameter="{Binding .}" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Grid Padding="12,8" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding DisplayName}" FontAttributes="Bold" />
                                        <Label Grid.Row="1" Grid.Column="0" Text="{Binding DeviceId}" Style="{StaticResource Caption}" LineBreakMode="TailTruncation" />
                                        <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="{Binding Role}" Style="{StaticResource CaptionBold}" VerticalOptions="Center" />
                                    </Grid>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
                <Label Text="Свайп влево по участнику — «Отозвать» (только Owner)."
                       Style="{StaticResource Caption}"
                       IsVisible="{Binding IsOwner}" />

                <!-- Manual fallback sync -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Ручная синхронизация" Style="{StaticResource H2}" />
                        <Label Text="Если UDP-broadcast не проходит (например, гостевой Wi-Fi), укажите IP вручную."
                               Style="{StaticResource Caption}" />
                        <Grid ColumnDefinitions="2*,*" ColumnSpacing="8">
                            <Border Grid.Column="0" Style="{StaticResource GlassInput}">
                                <Entry Placeholder="IP" BackgroundColor="Transparent" Text="{Binding PeerHost, Mode=TwoWay}" />
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource GlassInput}">
                                <Entry Placeholder="Port" BackgroundColor="Transparent" Text="{Binding PeerPort, Mode=TwoWay}" Keyboard="Numeric" />
                            </Border>
                        </Grid>
                        <Button Text="Синхронизировать" Style="{StaticResource GlassSecondary}" Command="{Binding SyncManualCommand}" />
                        <Label Text="{Binding Status}" Style="{StaticResource Caption}" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Покинуть семью"
                        BackgroundColor="{StaticResource DangerRed}"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        Padding="18,14"
                        MinimumHeightRequest="50"
                        Command="{Binding LeaveCommand}"
                        Margin="0,4,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
