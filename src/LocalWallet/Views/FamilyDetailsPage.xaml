<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.FamilyDetailsPage"
             x:DataType="vm:FamilyDetailsViewModel"
             Title="Семья">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding Family.Name, FallbackValue=Семья}" Style="{StaticResource SectionHeader}" />
                    <Label Text="{Binding Family.Role, StringFormat='Ваша роль: {0}'}" Style="{StaticResource FieldLabel}" />
                    <Label Text="{Binding LastSyncedText, StringFormat='Последняя синхронизация: {0}'}" Style="{StaticResource FieldLabel}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Участники" Style="{StaticResource SectionHeader}" />

            <Border Style="{StaticResource Card}" Padding="0">
                <CollectionView ItemsSource="{Binding Members}" SelectionMode="None" HeightRequest="200">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:FamilyMember">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Отозвать"
                                                   BackgroundColor="#D32F2F"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyDetailsViewModel}}, Path=RevokeMemberCommand}"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Grid Padding="14,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding DisplayName}" FontAttributes="Bold" />
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding DeviceId}" FontSize="10" TextColor="{StaticResource Gray500}" LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="{Binding Role}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                </Grid>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
            <Label Text="Свайп влево по участнику — «Отозвать» (только Owner)"
                   Style="{StaticResource FieldLabel}"
                   IsVisible="{Binding IsOwner}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Grid.Column="0" Text="Пригласить (QR)" Command="{Binding InviteCommand}" />
                <Button Grid.Column="1" Text="Чат семьи"
                        Command="{Binding OpenChatCommand}"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="White" />
            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Устройства в сети" Style="{StaticResource SectionHeader}" />
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{StaticResource Primary}"
                        VerticalOptions="Center"
                        Padding="8,3">
                    <Label FontSize="11" FontAttributes="Bold" TextColor="White">
                        <Label.Text>
                            <MultiBinding StringFormat="{}{0}">
                                <Binding Path="OnlinePeers.Count" />
                            </MultiBinding>
                        </Label.Text>
                    </Label>
                </Border>
            </Grid>
            <Label Text="Найдены по Wi-Fi автоматически. Тап — синхронизация прямо сейчас."
                   Style="{StaticResource FieldLabel}" />

            <Border Style="{StaticResource Card}" Padding="0">
                <CollectionView ItemsSource="{Binding OnlinePeers}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="16" Spacing="4" HorizontalOptions="Center">
                            <Label Text="Пока никого не видно" HorizontalOptions="Center" TextColor="{StaticResource Gray500}" FontSize="13" />
                            <Label Text="Откройте приложение на другом устройстве в той же Wi-Fi сети." HorizontalOptions="Center" TextColor="{StaticResource Gray500}" FontSize="11" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:OnlinePeer">
                            <Grid Padding="14,10" ColumnDefinitions="12,*,Auto" ColumnSpacing="10">
                                <Ellipse Grid.Column="0" WidthRequest="10" HeightRequest="10" Fill="#2E7D32" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                                    <Label Text="{Binding Endpoint}" FontSize="11" TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="2"
                                        Text="Синхр."
                                        FontSize="12"
                                        Padding="10,4"
                                        HeightRequest="34"
                                        MinimumHeightRequest="34"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyDetailsViewModel}}, Path=SyncPeerCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Label Text="Ручная синхронизация (если нужно указать адрес явно)"
                   Style="{StaticResource FieldLabel}" />

            <Grid ColumnDefinitions="2*,*" ColumnSpacing="8">
                <Border Grid.Column="0" Style="{StaticResource InputWrap}">
                    <Entry Placeholder="IP" Text="{Binding PeerHost, Mode=TwoWay}" />
                </Border>
                <Border Grid.Column="1" Style="{StaticResource InputWrap}">
                    <Entry Placeholder="Port" Text="{Binding PeerPort, Mode=TwoWay}" Keyboard="Numeric" />
                </Border>
            </Grid>
            <Button Text="Синхронизировать" Command="{Binding SyncManualCommand}" Style="{StaticResource Secondary}" />

            <Label Text="{Binding Status}" FontSize="12" TextColor="{StaticResource Gray500}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Button Text="Покинуть семью" BackgroundColor="#D32F2F" TextColor="White" Command="{Binding LeaveCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
