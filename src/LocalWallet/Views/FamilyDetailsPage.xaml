<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             xmlns:s="clr-namespace:LocalWallet.Services.Sync"
             x:Class="LocalWallet.Views.FamilyDetailsPage"
             x:DataType="vm:FamilyDetailsViewModel"
             Title="Семья">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding Family.Name, FallbackValue=Семья}" Style="{StaticResource SectionHeader}" />
                    <Label Text="{Binding Family.Role, StringFormat='Ваша роль: {0}'}" Style="{StaticResource FieldLabel}" />
                    <Label Text="{Binding LastSyncedText, StringFormat='Последняя синхронизация: {0}'}" Style="{StaticResource FieldLabel}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Участники" Style="{StaticResource SectionHeader}" />

            <Border Style="{StaticResource Card}" Padding="0">
                <CollectionView ItemsSource="{Binding Members}" SelectionMode="None" HeightRequest="180">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:FamilyMember">
                            <Grid Padding="14,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding DisplayName}" FontAttributes="Bold" />
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding DeviceId}" FontSize="10" TextColor="{StaticResource Gray500}" LineBreakMode="TailTruncation" />
                                <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="{Binding Role}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Button Text="Пригласить (QR)" Command="{Binding InviteCommand}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Устройства поблизости" Style="{StaticResource SectionHeader}" />
                <Button Grid.Column="1" Text="Обновить" Style="{StaticResource Secondary}" Command="{Binding RefreshPeersCommand}" />
            </Grid>

            <Border Style="{StaticResource Card}" Padding="0">
                <CollectionView ItemsSource="{Binding DiscoveredPeers}" SelectionMode="None" HeightRequest="160">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20" Spacing="4">
                            <Label Text="Устройства не найдены" FontSize="13" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                            <Label Text="Убедитесь, что оба телефона в одной сети" FontSize="11" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="s:DiscoveredPeer">
                            <Grid Padding="14,10" ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                                    <Label FontSize="11" TextColor="{StaticResource Gray500}">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0}:{1}">
                                                <Binding Path="Host" />
                                                <Binding Path="Port" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        Text="Sync"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyDetailsViewModel}}, Path=SyncWithPeerCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource Secondary}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Label Text="Вручную" Style="{StaticResource FieldLabel}" />
            <Grid ColumnDefinitions="2*,*" ColumnSpacing="8">
                <Border Grid.Column="0" Style="{StaticResource InputWrap}">
                    <Entry Placeholder="IP" Text="{Binding PeerHost, Mode=TwoWay}" />
                </Border>
                <Border Grid.Column="1" Style="{StaticResource InputWrap}">
                    <Entry Placeholder="Port" Text="{Binding PeerPort, Mode=TwoWay}" Keyboard="Numeric" />
                </Border>
            </Grid>
            <Button Text="Синхронизировать вручную" Command="{Binding SyncManualCommand}" Style="{StaticResource Secondary}" />

            <Label Text="{Binding Status}" FontSize="12" TextColor="{StaticResource Gray500}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Button Text="Покинуть семью" BackgroundColor="#D32F2F" TextColor="White" Command="{Binding LeaveCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
