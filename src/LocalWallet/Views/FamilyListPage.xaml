<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.FamilyListPage"
             x:DataType="vm:FamilyListViewModel"
             BackgroundColor="Transparent"
             Title="Семьи">

    <Grid Background="{StaticResource AmbientBg}">
        <Grid RowDefinitions="Auto,*" Padding="16,12,16,0" RowSpacing="14">

            <Border Grid.Row="0" Style="{StaticResource GlassCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Новая семья" Style="{StaticResource H2}" />
                    <Label Text="Вы станете владельцем. Затем пригласите других по QR."
                           Style="{StaticResource Caption}" />
                    <Border Style="{StaticResource GlassInput}">
                        <Entry Text="{Binding NewFamilyName, Mode=TwoWay}"
                               BackgroundColor="Transparent"
                               Placeholder="Название семьи" />
                    </Border>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="Создать" Style="{StaticResource GlassPrimary}" Command="{Binding CreateCommand}" />
                        <Button Grid.Column="1" Text="Сканировать QR" Style="{StaticResource GlassSecondary}" Command="{Binding JoinCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            VerticalScrollBarVisibility="Never">
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource GlassCard}" Margin="0,20">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Padding="8">
                            <Label Text="👪" FontSize="36" HorizontalOptions="Center" />
                            <Label Text="Пока нет семей" Style="{StaticResource H2}" HorizontalOptions="Center" />
                            <Label Text="Создайте семью или присоединитесь к существующей по QR-коду."
                                   Style="{StaticResource Caption}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:Family">
                        <Border Style="{StaticResource GlassRow}" Margin="0,5">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyListViewModel}}, Path=OpenCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="16" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Role}"
                                       Style="{StaticResource Caption}" />
                                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                        Text="Чат"
                                        Style="{StaticResource GlassSecondary}"
                                        Padding="14,6"
                                        HeightRequest="36"
                                        MinimumHeightRequest="36"
                                        FontSize="13"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyListViewModel}}, Path=OpenChatCommand}"
                                        CommandParameter="{Binding .}" />
                                <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                       Text="›"
                                       FontSize="22"
                                       TextColor="{StaticResource TextSecondaryLight}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>
