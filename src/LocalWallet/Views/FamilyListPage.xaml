<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.FamilyListPage"
             x:DataType="vm:FamilyListViewModel"
             Title="Семьи">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="14">

        <Border Grid.Row="0" Style="{StaticResource Card}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Новая семья" Style="{StaticResource SectionHeader}" />
                <Label Text="Вы станете владельцем. Затем пригласите других."
                       Style="{StaticResource FieldLabel}" />
                <Border Style="{StaticResource InputWrap}">
                    <Entry Text="{Binding NewFamilyName, Mode=TwoWay}" Placeholder="Название семьи" />
                </Border>
                <Button Text="Создать" Command="{Binding CreateCommand}" />
                <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />
                <Button Text="Присоединиться по QR"
                        Style="{StaticResource Secondary}"
                        Command="{Binding JoinCommand}" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20" Spacing="6">
                    <Label Text="Пока нет семей" FontSize="14" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                    <Label Text="Создайте новую или присоединитесь по QR" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:Family">
                    <Border Style="{StaticResource Card}" Padding="14" Margin="0,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyListViewModel}}, Path=OpenCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="6">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                            <Label Grid.Row="1" Grid.Column="0" Text="{Binding Role}" FontSize="12" TextColor="{StaticResource Gray500}" />
                            <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                    Text="Чат"
                                    FontSize="13"
                                    Padding="12,6"
                                    HeightRequest="36"
                                    MinimumHeightRequest="36"
                                    Style="{StaticResource Secondary}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FamilyListViewModel}}, Path=OpenChatCommand}"
                                    CommandParameter="{Binding .}" />
                            <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                   Text="›" FontSize="22" TextColor="{StaticResource Gray500}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
