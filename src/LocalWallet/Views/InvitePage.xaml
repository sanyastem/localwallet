<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.InvitePage"
             x:DataType="vm:InviteViewModel"
             Title="Пригласить">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14" HorizontalOptions="Center">

            <Label Text="{Binding Family.Name, StringFormat='Приглашение в «{0}»'}"
                   Style="{StaticResource SectionHeader}"
                   HorizontalOptions="Center" />

            <Label Text="Покажите QR-код другому устройству. Оно отсканирует и подключится."
                   Style="{StaticResource FieldLabel}"
                   HorizontalTextAlignment="Center" />

            <Border Style="{StaticResource Card}" Padding="12" HorizontalOptions="Center">
                <Image Source="{Binding QrImage}" HeightRequest="260" WidthRequest="260" Aspect="AspectFit" />
            </Border>

            <Label Text="{Binding HostInfo, StringFormat='Сеть: {0}'}"
                   FontSize="12"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Gray500}" />

            <Label Text="{Binding Status}" HorizontalTextAlignment="Center" FontSize="13" />

            <Border IsVisible="{Binding SasVisible}" Style="{StaticResource Card}" Padding="16" HorizontalOptions="Center">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="Код подтверждения" Style="{StaticResource FieldLabel}" HorizontalOptions="Center" />
                    <Label Text="{Binding Sas}"
                           FontSize="40"
                           FontAttributes="Bold"
                           CharacterSpacing="6"
                           HorizontalOptions="Center" />
                    <Label Text="Сверьте с кодом на втором устройстве и подтвердите"
                           Style="{StaticResource FieldLabel}"
                           HorizontalTextAlignment="Center" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="Отмена" Style="{StaticResource Secondary}" Command="{Binding CancelCommand}" />
                        <Button Grid.Column="1" Text="Коды совпадают" Command="{Binding ConfirmSasCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
