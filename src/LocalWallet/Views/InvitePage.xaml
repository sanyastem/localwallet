<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.InvitePage"
             x:DataType="vm:InviteViewModel"
             BackgroundColor="Transparent"
             Title="Пригласить">

    <Grid Background="{StaticResource AmbientBg}">
        <ScrollView>
            <VerticalStackLayout Padding="16,12,16,24" Spacing="14">

                <Label Style="{StaticResource H1}" HorizontalOptions="Center">
                    <Label.Text>
                        <MultiBinding StringFormat="Приглашение в «{0}»">
                            <Binding Path="Family.Name" FallbackValue="Семья" />
                        </MultiBinding>
                    </Label.Text>
                </Label>

                <Label Text="Покажите QR-код другому устройству — оно отсканирует и подключится."
                       Style="{StaticResource Caption}"
                       HorizontalTextAlignment="Center" />

                <Border Style="{StaticResource GlassCard}" Padding="20" HorizontalOptions="Center">
                    <Border BackgroundColor="White"
                            Stroke="Transparent"
                            Padding="12"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Image Source="{Binding QrImage}"
                               HeightRequest="260"
                               WidthRequest="260"
                               Aspect="AspectFit" />
                    </Border>
                </Border>

                <Border Style="{StaticResource GlassChip}" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Ellipse WidthRequest="6" HeightRequest="6" Fill="#2E7D32" VerticalOptions="Center" />
                        <Label Style="{StaticResource CaptionBold}" VerticalOptions="Center">
                            <Label.Text>
                                <MultiBinding StringFormat="LAN {0}">
                                    <Binding Path="HostInfo" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </HorizontalStackLayout>
                </Border>

                <Label Text="{Binding Status}" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />

                <!-- SAS confirmation -->
                <Border IsVisible="{Binding SasVisible}" Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="Код подтверждения" Style="{StaticResource CaptionBold}" HorizontalOptions="Center" />
                        <Label Text="{Binding Sas}"
                               Style="{StaticResource Display}"
                               CharacterSpacing="8"
                               HorizontalOptions="Center" />
                        <Label Text="Сверьте с кодом на втором устройстве."
                               Style="{StaticResource Caption}"
                               HorizontalTextAlignment="Center" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,6,0,0">
                            <Button Grid.Column="0" Text="Отмена" Style="{StaticResource GlassSecondary}" Command="{Binding CancelCommand}" />
                            <Button Grid.Column="1" Text="Коды совпадают" Style="{StaticResource GlassPrimary}" Command="{Binding ConfirmSasCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
