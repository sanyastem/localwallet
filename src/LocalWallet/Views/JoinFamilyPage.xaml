<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:zx="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="LocalWallet.Views.JoinFamilyPage"
             x:DataType="vm:JoinFamilyViewModel"
             Title="Присоединиться">

    <Grid RowDefinitions="*,Auto">

        <zx:CameraBarcodeReaderView Grid.Row="0"
                                    x:Name="Scanner"
                                    BarcodesDetected="OnBarcodesDetected"
                                    IsDetecting="{Binding CameraEnabled}" />

        <VerticalStackLayout Grid.Row="1" Padding="16" Spacing="10" BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1B1B}">
            <Label Text="{Binding Status}" HorizontalTextAlignment="Center" />

            <Border IsVisible="{Binding SasVisible}" Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="Код подтверждения" Style="{StaticResource FieldLabel}" HorizontalOptions="Center" />
                    <Label Text="{Binding Sas}"
                           FontSize="40"
                           FontAttributes="Bold"
                           CharacterSpacing="6"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding PeerDisplayName, StringFormat='Устройство: {0}'}"
                           Style="{StaticResource FieldLabel}"
                           HorizontalOptions="Center" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Text="Отмена" Style="{StaticResource Secondary}" Command="{Binding CancelCommand}" />
                        <Button Grid.Column="1" Text="Коды совпадают" Command="{Binding ConfirmSasCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
