<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LocalWallet.Views.LockPage"
             Shell.NavBarIsVisible="False"
             Title="Вход">
    <Grid BackgroundColor="{StaticResource Primary}">
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="24">
            <Label Text="🔒" FontSize="72" HorizontalOptions="Center" />
            <Label Text="Local Wallet" FontSize="32" TextColor="White" HorizontalOptions="Center" />
            <Label Text="Подтвердите вход" FontSize="16" TextColor="White" HorizontalOptions="Center" />
            <Button x:Name="RetryButton"
                    Text="Попробовать снова"
                    Clicked="OnRetryClicked"
                    BackgroundColor="White"
                    TextColor="{StaticResource Primary}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
