<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.MultiCurrencyPage"
             x:DataType="vm:MultiCurrencyViewModel"
             BackgroundColor="Transparent"
             Style="{StaticResource AppPage}"
             Title="Валюты">

    <Grid Background="{StaticResource AmbientBg}">
        <Grid RowDefinitions="*,Auto" Padding="16,12,16,100" RowSpacing="10">

            <RefreshView Grid.Row="0"
                         IsRefreshing="{Binding IsBusy, Mode=TwoWay}"
                         Command="{Binding RefreshRatesCommand}">
                <ScrollView>
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Общий баланс в выбранных валютах" Style="{StaticResource Caption}" />

                        <VerticalStackLayout IsVisible="{Binding HasAccounts}" Spacing="6">
                            <CollectionView ItemsSource="{Binding Balances}" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CurrencyBalance">
                                        <Border Style="{StaticResource GlassRow}" Margin="0,4">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Label Grid.Column="0"
                                                       Text="{Binding Currency}"
                                                       FontAttributes="Bold"
                                                       FontSize="18"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding AmountFormatted}"
                                                       FontSize="18"
                                                       HorizontalOptions="End"
                                                       VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <Border IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource GlassCard}">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center" Padding="8">
                                <Label Text="💱" FontSize="36" HorizontalOptions="Center" />
                                <Label Text="Нет счетов" Style="{StaticResource H2}" HorizontalOptions="Center" />
                                <Label Text="Добавьте счёт, чтобы увидеть баланс в разных валютах"
                                       Style="{StaticResource Caption}"
                                       HorizontalTextAlignment="Center" />
                                <Button Text="Создать счёт"
                                        Style="{StaticResource GlassPrimary}"
                                        Command="{Binding CreateAccountCommand}"
                                        Margin="0,4,0,0" />
                            </VerticalStackLayout>
                        </Border>

                        <Label Text="Курсы валют" Style="{StaticResource H2}" />

                        <CollectionView ItemsSource="{Binding Rates}"
                                        SelectionMode="None"
                                        IsVisible="{Binding HasRates}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:RateDisplay">
                                    <Border Style="{StaticResource GlassRow}" Margin="0,4">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="{Binding To}" FontAttributes="Bold" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding Pair}" Style="{StaticResource Caption}" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label IsVisible="{Binding HasRates, Converter={StaticResource InverseBool}}"
                               Text="Нажмите «Обновить курсы», чтобы загрузить"
                               Style="{StaticResource Caption}"
                               HorizontalOptions="Center"
                               Padding="0,12" />

                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>

            <VerticalStackLayout Grid.Row="1" Spacing="6">
                <Label Style="{StaticResource Caption}" HorizontalOptions="Center">
                    <Label.Text>
                        <MultiBinding StringFormat="Обновлено: {0}">
                            <Binding Path="LastUpdatedText" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Button Text="Обновить курсы" Style="{StaticResource GlassPrimary}" Command="{Binding RefreshRatesCommand}" />
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
