<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.MultiCurrencyPage"
             x:DataType="vm:MultiCurrencyViewModel"
             Title="Валюты">
    <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="12">

        <RefreshView Grid.Row="0"
                     IsRefreshing="{Binding IsBusy, Mode=TwoWay}"
                     Command="{Binding RefreshRatesCommand}">
            <ScrollView>
                <VerticalStackLayout Spacing="16">

                    <Label Text="Общий баланс в выбранных валютах"
                           FontSize="14"
                           TextColor="{StaticResource Gray500}" />

                    <VerticalStackLayout IsVisible="{Binding HasAccounts}" Spacing="8">
                        <CollectionView ItemsSource="{Binding Balances}"
                                        SelectionMode="None"
                                        HeightRequest="{OnIdiom Phone=220, Default=260}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CurrencyBalance">
                                    <Border Style="{StaticResource Card}" Margin="0,4">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Currency}"
                                                   FontAttributes="Bold"
                                                   FontSize="20"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding AmountFormatted}"
                                                   FontSize="20"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <Border IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Padding="8">
                            <Label Text="Нет счетов"
                                   FontSize="16" FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Label Text="Добавьте счёт, чтобы увидеть баланс в разных валютах"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalTextAlignment="Center" />
                            <Button Text="Создать счёт"
                                    Command="{Binding CreateAccountCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    Margin="0,4,0,0" />
                        </VerticalStackLayout>
                    </Border>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,4" />

                    <Label Text="Курсы валют" FontSize="16" FontAttributes="Bold" />

                    <CollectionView ItemsSource="{Binding Rates}"
                                    SelectionMode="None"
                                    IsVisible="{Binding HasRates}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:RateDisplay">
                                <Grid Padding="12,10" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding To}"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Pair}"
                                           FontSize="13"
                                           TextColor="{StaticResource Gray500}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label IsVisible="{Binding HasRates, Converter={StaticResource InverseBool}}"
                           Text="Нажмите «Обновить курсы», чтобы загрузить"
                           FontSize="13"
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center"
                           Padding="0,12" />

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <VerticalStackLayout Grid.Row="1" Spacing="6">
            <Label FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="Center">
                <Label.Text>
                    <MultiBinding StringFormat="Обновлено: {0}">
                        <Binding Path="LastUpdatedText" />
                    </MultiBinding>
                </Label.Text>
            </Label>
            <Button Text="Обновить курсы"
                    Command="{Binding RefreshRatesCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
