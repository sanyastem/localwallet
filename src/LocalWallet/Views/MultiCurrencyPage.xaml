<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.MultiCurrencyPage"
             x:DataType="vm:MultiCurrencyViewModel"
             Title="Валюты">
    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">

        <Label Grid.Row="0"
               Text="Общий баланс в выбранных валютах"
               FontSize="14"
               TextColor="{StaticResource Gray500}" />

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding LoadCommand}">
            <CollectionView ItemsSource="{Binding Balances}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CurrencyBalance">
                        <Border StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray300}"
                                Padding="16"
                                Margin="0,6">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0"
                                       Text="{Binding Currency}"
                                       FontAttributes="Bold"
                                       FontSize="20"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding AmountFormatted}"
                                       FontSize="20"
                                       HorizontalOptions="End"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <VerticalStackLayout Grid.Row="2" Spacing="4">
            <Label FontSize="12" TextColor="{StaticResource Gray500}">
                <Label.Text>
                    <MultiBinding StringFormat="Курсы обновлены: {0}">
                        <Binding Path="LastUpdatedText" />
                    </MultiBinding>
                </Label.Text>
            </Label>
            <Button Text="Обновить курсы"
                    Command="{Binding RefreshRatesCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
