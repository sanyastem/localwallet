<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.OnboardingPage"
             x:DataType="vm:OnboardingViewModel"
             Shell.NavBarIsVisible="False"
             Title="Добро пожаловать">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="16">

        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label Text="Добро пожаловать в LocalWallet"
                   FontSize="24" FontAttributes="Bold" />
            <Label Text="Настройте валюты и безопасность за одну минуту"
                   FontSize="14" TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="18">

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Базовая валюта" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Общий баланс будет считаться в ней"
                               FontSize="12" TextColor="{StaticResource Gray500}" />
                        <Picker ItemsSource="{Binding AvailableCurrencies}"
                                SelectedItem="{Binding SelectedBaseCurrency, Mode=TwoWay}"
                                ItemDisplayBinding="{Binding Display}"
                                Title="Выберите валюту" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Отображаемые валюты" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Баланс будет показан во всех выбранных"
                               FontSize="12" TextColor="{StaticResource Gray500}" />
                        <CollectionView ItemsSource="{Binding DisplayChoices}"
                                        SelectionMode="None"
                                        HeightRequest="320">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CurrencyChoice">
                                    <Grid Padding="4,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0"
                                               Text="{Binding Currency.Display}"
                                               VerticalOptions="Center" />
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Color="{StaticResource Primary}"
                                                  VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource Card}"
                        IsVisible="{Binding BiometricAvailable}">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Биометрический вход" FontSize="16" FontAttributes="Bold" />
                            <Label Text="Отпечаток / лицо при запуске приложения"
                                   FontSize="12" TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding BiometricEnabled, Mode=TwoWay}"
                                OnColor="{StaticResource Primary}"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Label Text="{Binding StatusText}"
                       IsVisible="{Binding IsBusy}"
                       FontSize="13"
                       TextColor="{StaticResource Gray500}"
                       HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="2"
                Text="Начать"
                Command="{Binding FinishCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />

    </Grid>
</ContentPage>
