<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Настройки">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="18">

            <Label Text="Валюты" FontSize="18" FontAttributes="Bold" />

            <Label Text="Базовая валюта" />
            <Picker ItemsSource="{Binding AvailableCurrencies}"
                    SelectedItem="{Binding SelectedBaseCurrency, Mode=TwoWay}"
                    ItemDisplayBinding="{Binding Display}"
                    Title="Выберите валюту" />

            <Label Text="Отображаемые валюты" />
            <Border Style="{StaticResource Card}" Padding="4">
                <CollectionView ItemsSource="{Binding DisplayChoices}"
                                SelectionMode="None"
                                HeightRequest="360">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:CurrencyChoice">
                            <Grid Padding="8,6" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding Currency.Display}"
                                       VerticalOptions="Center" />
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Color="{StaticResource Primary}"
                                          VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Button Text="Сохранить валюты"
                    Command="{Binding SaveCurrencyCommand}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Label Text="Безопасность" FontSize="18" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding BiometricAvailable}">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Биометрия при входе" FontAttributes="Bold" />
                    <Label Text="Отпечаток / лицо при запуске"
                           FontSize="12" TextColor="{StaticResource Gray500}" />
                </VerticalStackLayout>
                <Switch Grid.Column="1"
                        OnColor="{StaticResource Primary}"
                        IsToggled="{Binding BiometricEnabled, Mode=TwoWay}"
                        Toggled="OnBiometricToggled"
                        VerticalOptions="Center" />
            </Grid>
            <Label Text="Биометрия на устройстве не настроена"
                   FontSize="12"
                   TextColor="{StaticResource Gray500}"
                   IsVisible="{Binding BiometricAvailable, Converter={StaticResource InverseBool}}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Label Text="Это устройство" FontSize="18" FontAttributes="Bold" />
            <Label Text="Имя устройства (будет видно другим участникам семьи)"
                   Style="{StaticResource FieldLabel}" />
            <Border Style="{StaticResource InputWrap}">
                <Entry Text="{Binding DeviceDisplayName, Mode=TwoWay}" Placeholder="Моё устройство" />
            </Border>
            <Button Text="Сохранить имя" Command="{Binding SaveDeviceNameCommand}" />
            <Label FontSize="12" TextColor="{StaticResource Gray500}">
                <Label.Text>
                    <MultiBinding StringFormat="ID устройства: {0}">
                        <Binding Path="DeviceIdShort" />
                    </MultiBinding>
                </Label.Text>
            </Label>

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Label Text="Справочники" FontSize="18" FontAttributes="Bold" />
            <Button Text="Счета" Command="{Binding OpenAccountsCommand}" />
            <Button Text="Категории" Command="{Binding OpenCategoriesCommand}" />
            <Button Text="Семьи и синхронизация" Command="{Binding OpenFamiliesCommand}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Label Text="Курсы валют" FontSize="18" FontAttributes="Bold" />
            <Label FontSize="12" TextColor="{StaticResource Gray500}">
                <Label.Text>
                    <MultiBinding StringFormat="Последнее обновление: {0}">
                        <Binding Path="LastRatesUpdateText" />
                    </MultiBinding>
                </Label.Text>
            </Label>
            <Button Text="Обновить курсы" Command="{Binding RefreshRatesCommand}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />

            <Label Text="Данные" FontSize="18" FontAttributes="Bold" />

            <Button Text="Экспорт в CSV" Command="{Binding ExportCsvCommand}" />

            <Label Text="Удалить операции за период" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <DatePicker Grid.Column="0" Date="{Binding DeleteFromDate, Mode=TwoWay}" />
                <DatePicker Grid.Column="1" Date="{Binding DeleteToDate, Mode=TwoWay}" />
            </Grid>
            <Button Text="Удалить за период"
                    Command="{Binding DeletePeriodCommand}"
                    BackgroundColor="#D32F2F" TextColor="White" />

            <Button Text="Сбросить все данные"
                    Command="{Binding ResetAllCommand}"
                    BackgroundColor="#B71C1C" TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
