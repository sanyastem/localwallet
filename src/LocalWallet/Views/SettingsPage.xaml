<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:m="clr-namespace:LocalWallet.Models"
             x:Class="LocalWallet.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             BackgroundColor="Transparent"
             Title="Настройки">

    <Grid Background="{StaticResource AmbientBg}">
        <ScrollView>
            <VerticalStackLayout Padding="16,12,16,24" Spacing="14">

                <!-- Currencies -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Валюты" Style="{StaticResource H2}" />
                        <Label Text="Базовая валюта" Style="{StaticResource Caption}" />
                        <Border Style="{StaticResource GlassInput}">
                            <Picker ItemsSource="{Binding AvailableCurrencies}"
                                    BackgroundColor="Transparent"
                                    SelectedItem="{Binding SelectedBaseCurrency, Mode=TwoWay}"
                                    ItemDisplayBinding="{Binding Display}"
                                    Title="Выберите валюту" />
                        </Border>

                        <Label Text="Отображаемые валюты" Style="{StaticResource Caption}" />
                        <CollectionView ItemsSource="{Binding DisplayChoices}"
                                        SelectionMode="None"
                                        HeightRequest="320">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CurrencyChoice">
                                    <Grid Padding="4,6" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="{Binding Currency.Display}" VerticalOptions="Center" />
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Color="{StaticResource AccentGreen}"
                                                  VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Button Text="Сохранить валюты" Style="{StaticResource GlassPrimary}" Command="{Binding SaveCurrencyCommand}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Security -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Безопасность" Style="{StaticResource H2}" />
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding BiometricAvailable}">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Биометрия при входе" FontAttributes="Bold" />
                                <Label Text="Отпечаток / лицо при запуске" Style="{StaticResource Caption}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    OnColor="{StaticResource AccentGreen}"
                                    IsToggled="{Binding BiometricEnabled, Mode=TwoWay}"
                                    Toggled="OnBiometricToggled"
                                    VerticalOptions="Center" />
                        </Grid>
                        <Label Text="Биометрия на устройстве не настроена"
                               Style="{StaticResource Caption}"
                               IsVisible="{Binding BiometricAvailable, Converter={StaticResource InverseBool}}" />
                    </VerticalStackLayout>
                </Border>

                <!-- This device -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Это устройство" Style="{StaticResource H2}" />
                        <Label Text="Имя устройства (видно другим участникам семьи)" Style="{StaticResource Caption}" />
                        <Border Style="{StaticResource GlassInput}">
                            <Entry Text="{Binding DeviceDisplayName, Mode=TwoWay}"
                                   BackgroundColor="Transparent"
                                   Placeholder="Моё устройство" />
                        </Border>
                        <Button Text="Сохранить имя" Style="{StaticResource GlassSecondary}" Command="{Binding SaveDeviceNameCommand}" />
                        <Label Style="{StaticResource Caption}">
                            <Label.Text>
                                <MultiBinding StringFormat="ID устройства: {0}">
                                    <Binding Path="DeviceIdShort" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <!-- Directories -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Справочники" Style="{StaticResource H2}" />
                        <Button Text="Счета" Style="{StaticResource GlassSecondary}" Command="{Binding OpenAccountsCommand}" />
                        <Button Text="Категории" Style="{StaticResource GlassSecondary}" Command="{Binding OpenCategoriesCommand}" />
                        <Button Text="Семьи и синхронизация" Style="{StaticResource GlassSecondary}" Command="{Binding OpenFamiliesCommand}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Rates -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Курсы валют" Style="{StaticResource H2}" />
                        <Label Style="{StaticResource Caption}">
                            <Label.Text>
                                <MultiBinding StringFormat="Последнее обновление: {0}">
                                    <Binding Path="LastRatesUpdateText" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Button Text="Обновить курсы" Style="{StaticResource GlassPrimary}" Command="{Binding RefreshRatesCommand}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Data -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Данные" Style="{StaticResource H2}" />
                        <Button Text="Экспорт в CSV" Style="{StaticResource GlassSecondary}" Command="{Binding ExportCsvCommand}" />

                        <Label Text="Удалить операции за период" Style="{StaticResource Caption}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <DatePicker Grid.Column="0" Date="{Binding DeleteFromDate, Mode=TwoWay}" />
                            <DatePicker Grid.Column="1" Date="{Binding DeleteToDate, Mode=TwoWay}" />
                        </Grid>
                        <Button Text="Удалить за период"
                                BackgroundColor="{StaticResource DangerRed}"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="16"
                                Padding="18,14"
                                MinimumHeightRequest="50"
                                Command="{Binding DeletePeriodCommand}" />
                        <Button Text="Сбросить все данные"
                                BackgroundColor="#B71C1C"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="16"
                                Padding="18,14"
                                MinimumHeightRequest="50"
                                Command="{Binding ResetAllCommand}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
