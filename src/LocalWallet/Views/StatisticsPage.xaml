<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="LocalWallet.Views.StatisticsPage"
             x:DataType="vm:StatisticsViewModel"
             BackgroundColor="Transparent"
             Title="Статистика">

    <Grid Background="{StaticResource AmbientBg}">
        <ScrollView>
            <VerticalStackLayout Padding="16,12,16,24" Spacing="14">

                <Border Style="{StaticResource GlassCard}" Padding="14,12">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="С" Style="{StaticResource Caption}" />
                                <DatePicker Date="{Binding FromDate, Mode=TwoWay}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="По" Style="{StaticResource Caption}" />
                                <DatePicker Date="{Binding ToDate, Mode=TwoWay}" />
                            </VerticalStackLayout>
                        </Grid>
                        <Button Text="Применить" Style="{StaticResource GlassPrimary}" Command="{Binding LoadCommand}" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="14,12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Доход" Style="{StaticResource Caption}" TextColor="{StaticResource IncomeGreen}" />
                            <Label FontSize="18" FontAttributes="Bold">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0:0.00} {1}">
                                        <Binding Path="TotalIncome" />
                                        <Binding Path="BaseCurrency" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="14,12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Расход" Style="{StaticResource Caption}" TextColor="{StaticResource DangerRed}" />
                            <Label FontSize="18" FontAttributes="Bold">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0:0.00} {1}">
                                        <Binding Path="TotalExpenses" />
                                        <Binding Path="BaseCurrency" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Style="{StaticResource GlassCard}" Padding="8">
                    <microcharts:ChartView Chart="{Binding ExpensesChart}" HeightRequest="260" />
                </Border>

                <Label Text="По категориям" Style="{StaticResource H2}" />
                <Border Style="{StaticResource GlassCard}" Padding="6">
                    <CollectionView ItemsSource="{Binding CategoryStats}" HeightRequest="280">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:CategoryStat">
                                <Grid Padding="10,8" ColumnDefinitions="20,*,Auto" ColumnSpacing="10">
                                    <BoxView Grid.Column="0" Color="{Binding ColorHex}" WidthRequest="12" HeightRequest="12" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding AmountFormatted}" FontAttributes="Bold" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
