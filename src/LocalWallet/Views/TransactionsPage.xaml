<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LocalWallet.ViewModels"
             x:Class="LocalWallet.Views.TransactionsPage"
             x:DataType="vm:TransactionsViewModel"
             BackgroundColor="Transparent"
             Style="{StaticResource AppPage}"
             Title="Операции">

    <Grid Background="{StaticResource AmbientBg}">
        <Grid RowDefinitions="Auto,*" Padding="16,12,16,96" RowSpacing="10">

            <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="14,12">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="С" Style="{StaticResource Caption}" />
                        <DatePicker Date="{Binding FromDate, Mode=TwoWay}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="По" Style="{StaticResource Caption}" />
                        <DatePicker Date="{Binding ToDate, Mode=TwoWay}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <RefreshView Grid.Row="1"
                         IsRefreshing="{Binding IsBusy, Mode=TwoWay}"
                         Command="{Binding LoadCommand}">
                <CollectionView ItemsSource="{Binding Items}" VerticalScrollBarVisibility="Never">
                    <CollectionView.EmptyView>
                        <Border Style="{StaticResource GlassCard}" Margin="0,32">
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="📒" FontSize="36" HorizontalOptions="Center" />
                                <Label Text="Пусто за этот период" Style="{StaticResource H2}" HorizontalOptions="Center" />
                                <Label Text="Добавьте первую операцию, нажав +."
                                       Style="{StaticResource Caption}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TransactionDisplay">
                            <SwipeView Margin="0,5">
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Удалить"
                                                   BackgroundColor="{StaticResource DangerRed}"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TransactionsViewModel}}, Path=DeleteCommand}"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Border Style="{StaticResource GlassRow}">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding CategoryName}"
                                               FontSize="15"
                                               FontAttributes="Bold" />
                                        <Label Grid.Row="1" Grid.Column="0" Style="{StaticResource Caption}">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0:dd.MM.yyyy HH:mm} · {1}">
                                                    <Binding Path="Date" />
                                                    <Binding Path="AccountName" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                               Text="{Binding AmountFormatted}"
                                               TextColor="{Binding AmountColor}"
                                               FontSize="15"
                                               VerticalOptions="Center"
                                               FontAttributes="Bold" />
                                    </Grid>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

        </Grid>

        <Button Text="+"
                FontSize="28"
                FontAttributes="Bold"
                WidthRequest="60" HeightRequest="60"
                MinimumHeightRequest="60" MinimumWidthRequest="60"
                CornerRadius="30"
                Padding="0"
                BackgroundColor="{StaticResource AccentGreen}"
                TextColor="White"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,110"
                Command="{Binding AddCommand}">
            <Button.Shadow>
                <Shadow Brush="Black" Opacity="0.25" Radius="14" Offset="0,6" />
            </Button.Shadow>
        </Button>
    </Grid>
</ContentPage>
